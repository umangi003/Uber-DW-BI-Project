              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[dbo].[Stg_UberTrips]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    trip_uid,
    trip_status,
    trip_type,
    TRY_CAST(surge_multiplier AS FLOAT) AS surge_multiplier,
    TRY_CAST(price_usd AS FLOAT) AS price_usd,
    TRY_CAST(distance_kms AS FLOAT) AS distance_kms,
    trip_time,
    total_time,
    wait_time,
    driver_uid,
    rider_uid,
    vehicle_make,
    vehicle_model,
    city,
    country,
    weather_main,
    weather_desc,
    TRY_CAST(temperature_value AS FLOAT) AS temperature_value,
    
    -- THE FIX IS HERE: Changed CONVERT to TRY_CONVERT to safely ignore bad text
    TRY_CONVERT(INT, FORMAT(
        TRY_CONVERT(DATE, 
            SUBSTRING(trip_completed_at, 
            CHARINDEX(',', trip_completed_at) + 2, 
            LEN(trip_completed_at)), 107)
        , 'yyyyMMdd')) AS date_key

FROM Stg_UberTrips
WHERE trip_completed_at IS NOT NULL</property>
